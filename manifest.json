{
  "manifest_version": 3,
  "name": "IPL Fantasy Advisor",
  "version": "1.0.0",
  "description": "AI-powered transfer recommendations for TATA IPL Season Long Fantasy 2026. Uses Gemini to analyze your squad and suggest optimal transfers.",
  "permissions": [
    "sidePanel",
    "activeTab",
    "scripting",
    "storage"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Open IPL Fantasy Advisor",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://fantasy.iplt20.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*",
    "*://fantasy.iplt20.com/*"
  ]
}
